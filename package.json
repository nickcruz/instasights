{
  "name": "instagram-insights",
  "private": true,
  "packageManager": "yarn@1.22.22",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev": "yarn workspace @instagram-insights/web dev",
    "build": "yarn workspace @instagram-insights/cli build && yarn workspace @instagram-insights/web build",
    "build:cli": "yarn workspace @instagram-insights/cli build",
    "package:cli:macos": "yarn workspace @instagram-insights/cli package:macos",
    "lint": "yarn workspace @instagram-insights/web lint",
    "typecheck": "yarn workspace @instagram-insights/cli typecheck && yarn workspace @instagram-insights/web typecheck",
    "test": "yarn test:cli && yarn test:web && yarn test:transcriber",
    "test:cli": "yarn workspace @instagram-insights/cli test",
    "test:web": "yarn workspace @instagram-insights/web test",
    "test:transcriber": "python3 -m pytest services/transcriber/tests",
    "infra:synth": "yarn workspace @instagram-insights/infra synth",
    "db:generate": "yarn workspace @instagram-insights/db db:generate",
    "db:push": "yarn workspace @instagram-insights/db db:push"
  },
  "devDependencies": {
    "esbuild": "^0.25.11",
    "tsx": "^4.21.0"
  }
}
