# App auth
AUTH_SECRET="replace-with-a-long-random-secret"
AUTH_GOOGLE_ID="your-google-oauth-client-id"
AUTH_GOOGLE_SECRET="your-google-oauth-client-secret"

# Database
DATABASE_URL="postgres://USER:PASSWORD@HOST:5432/instagram_insights?sslmode=require"

# Instagram OAuth
INSTAGRAM_APP_ID="your-instagram-app-id"
INSTAGRAM_APP_SECRET="your-instagram-app-secret"
INSTAGRAM_APP_URL="http://localhost:3000"
INSTAGRAM_REDIRECT_URI="http://localhost:3000/api/callback"
GRAPH_API_VERSION="v25.0"

# Optional
# INSTAGRAM_GRAPH_BASE_URL="https://graph.instagram.com"
# INSTAGRAM_INSIGHTS_CLI_MANIFEST_URL="https://example.com/cli/latest.json"
